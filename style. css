/*==========================
        GOOGLE FONT
==========================*/

@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

/*==========================
        ROOT VARIABLES
==========================*/

:root{

    --bg:#050816;
    --bg2:#0b1120;

    --primary:#7c5cff;
    --secondary:#4fd1ff;

    --white:#ffffff;
    --text:#cfd8ff;
    --muted:#8b93b6;

    --glass:rgba(255,255,255,.08);
    --glass2:rgba(255,255,255,.04);

    --border:rgba(255,255,255,.12);

    --shadow:
    0 15px 40px rgba(0,0,0,.45);

    --radius:22px;

    --transition:.4s ease;

}

/*==========================
        RESET
==========================*/

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{

    scroll-behavior:smooth;

}

body{

    font-family:'Poppins',sans-serif;

    background:var(--bg);

    color:var(--white);

    overflow-x:hidden;

}

/*==========================
        SCROLLBAR
==========================*/

::-webkit-scrollbar{

    width:10px;

}

::-webkit-scrollbar-track{

    background:#050816;

}

::-webkit-scrollbar-thumb{

    background:linear-gradient(
    180deg,
    var(--primary),
    var(--secondary));

    border-radius:20px;

}

/*==========================
        SELECTION
==========================*/

::selection{

    background:var(--primary);

    color:#fff;

}

/*==========================
        CONTAINER
==========================*/

.container{

    width:90%;

    max-width:1200px;

    margin:auto;

}

/*==========================
        SECTION
==========================*/

section{

    padding:120px 0;

    position:relative;

}

/*==========================
        TITLES
==========================*/

.section-title{

    text-align:center;

    margin-bottom:70px;

}

.section-title span{

    color:var(--secondary);

    letter-spacing:2px;

    text-transform:uppercase;

    font-size:14px;

}

.section-title h2{

    margin-top:12px;

    font-size:42px;

}

/*==========================
        BACKGROUND
==========================*/

.bg-gradient{

    position:fixed;

    inset:0;

    z-index:-3;

    background:
    radial-gradient(circle at 20% 20%,
    rgba(124,92,255,.28),
    transparent 40%),

    radial-gradient(circle at 80% 25%,
    rgba(79,209,255,.18),
    transparent 35%),

    radial-gradient(circle at 50% 80%,
    rgba(124,92,255,.18),
    transparent 35%),

    #050816;

}

/*==========================
        INSTAGRAM LAMP
==========================*/

.lamp{

    position:fixed;

    top:-220px;

    left:50%;

    transform:translateX(-50%);

    width:900px;

    height:900px;

    border-radius:50%;

    background:

    radial-gradient(circle,
    rgba(124,92,255,.40),
    rgba(79,209,255,.18),
    transparent 65%);

    filter:blur(70px);

    animation:lampMove 8s ease-in-out infinite;

    z-index:-2;

}

@keyframes lampMove{

    0%{

        transform:
        translateX(-50%)
        scale(1);

    }

    50%{

        transform:
        translateX(-50%)
        scale(1.08);

    }

    100%{

        transform:
        translateX(-50%)
        scale(1);

    }

}

/*==========================
        PRELOADER
==========================*/

#preloader{

    position:fixed;

    inset:0;

    background:#050816;

    display:flex;

    justify-content:center;

    align-items:center;

    z-index:99999;

}

.loader{

    display:flex;

    gap:12px;

}

.loader span{

    width:18px;

    height:18px;

    border-radius:50%;

    background:var(--primary);

    animation:bounce .8s infinite alternate;

}

.loader span:nth-child(2){

    animation-delay:.2s;

}

.loader span:nth-child(3){

    animation-delay:.4s;

}

@keyframes bounce{

    to{

        transform:
        translateY(-20px);

        background:var(--secondary);

    }

}

/*==========================
        CURSOR
==========================*/

.cursor{

    width:25px;

    height:25px;

    border:2px solid var(--secondary);

    border-radius:50%;

    position:fixed;

    pointer-events:none;

    transform:translate(-50%,-50%);

    z-index:9999;

    transition:.08s linear;

}

/*==========================
        PROGRESS BAR
==========================*/

#progressBar{

    position:fixed;

    top:0;

    left:0;

    width:0%;

    height:4px;

    background:

    linear-gradient(
    90deg,
    var(--primary),
    var(--secondary));

    z-index:9999;

}

